hostname {{ inventory_hostname }}

{% if loopback_ip is defined %}
interface Loopback0
 ip address {{ loopback_ip }} 255.255.255.255
!
{% endif %}

{% for intf in interfaces | default([]) %}
interface {{ intf.name }}

{% if intf.apply_ip | default(false) and intf.ip is defined and intf.mask is defined %}
 ip address {{ intf.ip }} {{ intf.mask }}
{% endif %}

 no shutdown
!
{% endfor %}

{% if ospf is defined %}
router ospf {{ ospf.process_id }}
 router-id {{ loopback_ip | default('1.1.1.1') }}
{% for net in ospf.networks | default([]) %}
 network {{ net.network }} {{ net.wildcard }} area {{ net.area }}
{% endfor %}
!
{% endif %}

{% if bgp is defined %}
router bgp {{ bgp.asn }}
 bgp log-neighbor-changes

{% for neigh in bgp.neighbors | default([]) %}
 neighbor {{ neigh.ip }} remote-as {{ neigh.remote_as }}
 neighbor {{ neigh.ip }} update-source Loopback0
{% endfor %}

 address-family ipv4
{% for neigh in bgp.neighbors | default([]) %}
  neighbor {{ neigh.ip }} activate
{% endfor %}
 exit-address-family
!
{% endif %}